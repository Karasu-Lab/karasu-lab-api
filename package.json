{
  "name": "@karasu-lab/karasu-lab-api",
  "version": "5.5.0",
  "description": "",
  "author": "",
  "private": true,
  "type": "module",
  "license": "MIT",
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "test": "vp test run",
    "test:watch": "vp test",
    "test:cov": "vp test run --coverage",
    "test:debug": "vp test --inspect-brk",
    "test:e2e": "vp test run --config ./vitest.config.ts",
    "emulator:start": "firebase emulators:start --only firestore",
    "lint": "vp lint src test",
    "lint:fix": "vp lint src test --fix",
    "format": "vp fmt --ignore-path .gitignore './**/*.{js,ts,json}'",
    "deploy": "sh scripts/deploy.sh",
    "setup": "sh scripts/setup.sh",
    "prisma:generate": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:push": "npx prisma db push",
    "prisma:pull": "npx prisma db pull"
  },
  "dependencies": {
    "@apollo/server": "^5.5.0",
    "@as-integrations/express5": "^1.1.2",
    "@aws-sdk/client-s3": "^3.999.0",
    "@aws-sdk/s3-request-presigner": "^3.999.0",
    "@better-auth/api-key": "^1.6.9",
    "@better-auth/infra": "^0.1.12",
    "@better-auth/passkey": "^1.6.9",
    "@hashibutogarasu/common": "workspace:*",
    "@nestjs/apollo": "^13.3.0",
    "@nestjs/common": "^11.1.14",
    "@nestjs/core": "^11.1.14",
    "@nestjs/graphql": "^13.3.0",
    "@nestjs/platform-express": "^11.1.14",
    "@nestjs/swagger": "^11.2.6",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.4.1",
    "@prisma/config": "^7.4.1",
    "@prisma/extension-accelerate": "^2.0.2",
    "@simplewebauthn/server": "^13.2.3",
    "@thallesp/nestjs-better-auth": "^2.5.1",
    "better-auth": "^1.6.9",
    "better-call": "1.3.5",
    "cross-env": "^10.1.0",
    "cuid": "^3.0.0",
    "dotenv": "^17.3.1",
    "firebase": "^12.10.0",
    "firebase-admin": "^13.7.0",
    "graphql": "^16.13.2",
    "i18next": "^25.8.13",
    "kysely": "^0.28.11",
    "nestjs-zod": "^5.1.1",
    "pg": "^8.18.0",
    "prisma": "^7.4.1",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.9.2",
    "rxjs": "^7.8.2",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@apollo/protobufjs",
      "@firebase/util",
      "@hashibutogarasu/common",
      "@nestjs/core",
      "@prisma/client",
      "@prisma/engines",
      "@scarf/scarf",
      "@swc/core",
      "@thallesp/nestjs-better-auth",
      "better-sqlite3",
      "esbuild",
      "prisma",
      "protobufjs",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.4",
    "@eslint/js": "^9.39.3",
    "@flydotio/dockerfile": "^0.7.10",
    "@nestjs/cli": "^11.0.16",
    "@nestjs/schematics": "^11.0.9",
    "@nestjs/testing": "^11.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/node": "^22.19.11",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "better-sqlite3": "^12.6.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-sort-keys-fix": "^1.1.2",
    "eslint-plugin-typescript-sort-keys": "^3.3.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^16.5.0",
    "jest-mock-extended": "^4.0.0",
    "nest-prettier": "^0.0.4",
    "source-map-support": "^0.5.21",
    "supertest": "^7.2.2",
    "ts-loader": "^9.5.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "unplugin-swc": "^1.5.9",
    "vite-plus": "catalog:",
    "vitest": "catalog:",
    "vitest-mock-extended": "^3.1.0"
  },
  "eslintConfig": {
    "extends": [
      "plugin:prettier/recommended"
    ],
    "rules": {
      "prettier/prettier": [
        "error",
        {
          "sourceRoot": "src",
          "printWidth": 100,
          "tabWidth": 2,
          "useTabs": true,
          "semi": true,
          "singleQuote": true,
          "quoteProps": "preserve",
          "trailComma": "es5",
          "bracketSpacing": true,
          "arrowParens": "always",
          "requirePragma": true,
          "insertPragma": true
        }
      ]
    }
  },
  "packageManager": "pnpm@10.33.0"
}
